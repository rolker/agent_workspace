# Project directory (managed externally — cloned or symlinked)
project/

# Worktrees (workspace and project, see issue #25)
worktrees/

# Legacy worktree location (deprecated — remove after migration)
.workspace-worktrees/

# Make stamp files (setup state tracking — see ADR-0007)
.make/

# Dev-tools virtual environment (pre-commit, linters)
.venv/

# IDE settings
.vscode/
*.code-workspace
.codex

# Generated Claude Code skills (regenerate with: make generate-skills)
.claude/skills/make_*/

# Claude Code harness runtime state (per-session lock files; ephemeral, never committed)
.claude/*.lock

# Agent Scratchpad (Temporary files and artifacts)
.agent/scratchpad/*
!.agent/scratchpad/README.md

# Agent Identity (Runtime-generated, not template)
.agent/.identity

# Project config (per-developer, per-project — not committed)
.agent/project_config.sh

.env

# Python cache files
__pycache__/
*.py[cod]
*$py.class
*.so

# CodeQL generated files
_codeql_detected_source_root

# Cross-model review artifacts (see #193)
# Regenerated each /review-code run; bloats PR diffs and recursively grows
# until it breaks Codex's 1MB context window. Patterns are suffix-anchored
# (-prompt.md / -findings.md) so a future tracked review-*-summary.md
# audit-trail file is not caught.
.agent/work-plans/*/review-*-prompt.md
.agent/work-plans/*/review-*-findings.md
